<div class="container mt-5">
  <h1>Create a New Restaurant</h1>
  <%= simple_form_for(@restaurant) do |f| %>
    <%= f.input :name %>
    <%= f.input :address %>
    <%= f.input :phone_number %>
    <%= f.input :category, collection: Restaurant::CATEGORIES %>
    <%= f.submit %>
  <% end %>

  <hr>
  <%= link_to "Back to list", restaurants_path %>
</div>
